@model BouchonUniversel.Models.Bouchons.Service

@{
    this.ViewData["Title"] = "Edit";
    this.Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Edit</h2>

<h4>Service</h4>
<hr/>
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Cle" class="control-label"></label>
                <input asp-for="Cle" class="form-control"/>
                <span asp-validation-for="Cle" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="EnvironnementId" class="control-label"></label>
                <select asp-for="EnvironnementId" class="form-control" asp-items="this.ViewBag.EnvironnementId"></select>
                <span asp-validation-for="EnvironnementId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Url" class="control-label"></label>
                <input asp-for="Url" class="form-control"/>
                <span asp-validation-for="Url" class="text-danger"></span>
            </div>
            <input type="hidden" asp-for="Id"/>
            <div class="form-group">
                <div class="checkbox">
                    <label>
                        <input asp-for="IsEnabled"/> @(this.Html.DisplayNameFor(model => model.IsEnabled))
                    </label>
                </div>
            </div>
            <!-- Ajout -->
            <div class="form-group">
                <div class="checkbox">
                    <label>
                        <input asp-for="UpdateDates"/> @(this.Html.DisplayNameFor(model => model.UpdateDates))
                    </label>
                </div>
            </div>
            <hr/>
            <p class="text-muted">Ingénierie du chaos (facultatif)</p>
            <div class="form-group">
                <label asp-for="LatencyMs" class="control-label">Latence simulée (ms)</label>
                <input asp-for="LatencyMs" class="form-control" type="number" min="0"/>
            </div>
            <div class="form-group">
                <label asp-for="ErrorProbability" class="control-label">Probabilité d'erreur (0-100)</label>
                <input asp-for="ErrorProbability" class="form-control" type="number" min="0" max="100"/>
            </div>
            <div class="form-group">
                <label asp-for="ErrorStatusCode" class="control-label">Code d'erreur simulé (500 par défaut)</label>
                <input asp-for="ErrorStatusCode" class="form-control" type="number" min="0"/>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-default"/>
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{ await this.Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
