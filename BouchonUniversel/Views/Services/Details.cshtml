@model BouchonUniversel.Models.ModelsView.DetailsServiceViewModel

@{
    this.ViewData["Title"] = "Details";
    this.Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Details</h2>

<div>
    <h4>Service</h4>
    <hr/>
    <dl class="dl-horizontal">
        <dt>
            @(this.Html.DisplayNameFor(model => model.Service.Cle))
        </dt>
        <dd>
            @(this.Html.DisplayFor(model => model.Service.Cle))
        </dd>
        <dt>
            @(this.Html.DisplayNameFor(model => model.Service.Url))
        </dt>
        <dd>
            @(this.Html.DisplayFor(model => model.Service.Url))
        </dd>
        <dt>
            @(this.Html.DisplayNameFor(model => model.Service.IsEnabled))
        </dt>
        <dd>
            @(this.Html.DisplayFor(model => model.Service.IsEnabled))
        </dd>
        <dt>
            @(this.Html.DisplayNameFor(model => model.Service.UpdateDates))
        </dt>
        <dd>
            @(this.Html.DisplayFor(model => model.Service.UpdateDates))
        </dd>
        <dt>
            @(this.Html.DisplayNameFor(model => model.Service.Environnement))
        </dt>
        <dd>
            @(this.Html.DisplayFor(model => model.Service.Environnement.Nom))
        </dd>
    </dl>
</div>

<div>
    <p>Url du bouchon : <a href="https://@(this.Context.Request.Host)/api/bouchon/@(this.Model.Service.Cle)/@(this.Model.Service.Environnement.Nom)/">https://@(this.Context.Request.Host)/api/bouchon/@(this.Model.Service.Cle)/@(this.Model.Service.Environnement.Nom)/</a></p>
    <h4>Liste des fichiers pour ce bouchon :</h4>
    @(this.Html.DisplayFor(model => model.ListeFichiers))
</div>

<div>
    <a asp-action="Edit" asp-route-id="@(this.Model.Service.Id)">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>
