        <dd>
            @Html.DisplayFor(model => model.Service.Cle)
        </dd>
        <dt>
            @Html.DisplayNameFor(model => model.Service.Url)
        </dt>
        <dd>
            @Html.DisplayFor(model => model.Service.Url)
        </dd>
        <dt>
            @Html.DisplayNameFor(model => model.Service.IsEnabled)
        </dt>
        <dd>
            @Html.DisplayFor(model => model.Service.IsEnabled)
