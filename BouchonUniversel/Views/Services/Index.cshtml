@model IEnumerable<BouchonUniversel.Models.Bouchons.Service>

@{
    this.ViewData["Title"] = "Index";
    this.Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Index</h2>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
    <tr>
        <th>
            @(this.Html.DisplayNameFor(model => model.Cle))
        </th>
        <th>
            @(this.Html.DisplayNameFor(model => model.Url))
        </th>
        <th>
            @(this.Html.DisplayNameFor(model => model.IsEnabled))
        </th>
        <th>
            @(this.Html.DisplayNameFor(model => model.UpdateDates))
        </th>
        <th>
            @(this.Html.DisplayNameFor(model => model.Environnement))
        </th>
        <th></th>
    </tr>
    </thead>
    <tbody>
    @foreach (var item in this.Model)
    {
        <tr>
            <td>
                @(this.Html.DisplayFor(modelItem => item.Cle))
            </td>
            <td>
                <a href="@item.Url" target="_blank">@item.Url</a>
            </td>
            <td>
                @(this.Html.DisplayFor(modelItem => item.IsEnabled))
            </td>
            <td>
                @(this.Html.DisplayFor(modelItem => item.UpdateDates))
            </td>
            <td>
                @(this.Html.DisplayFor(modelItem => item.Environnement.Nom))
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>
