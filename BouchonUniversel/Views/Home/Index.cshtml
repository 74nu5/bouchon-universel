@model BouchonUniversel.Models.ModelsView.DashboardViewModel

@{
    this.ViewData["Title"] = "Tableau de bord";
}

<h2 class="mb-4"><i class="bi bi-speedometer2"></i> Tableau de bord</h2>

<div class="row row-cols-1 row-cols-md-3 g-3 mb-4">
    <div class="col">
        <div class="card stat-card h-100">
            <div class="card-body d-flex align-items-center">
                <i class="bi bi-hdd-network fs-1 text-primary me-3"></i>
                <div>
                    <div class="stat-value">@(this.Model.ServicesCount)</div>
                    <div class="text-body-secondary">Services</div>
                </div>
                <a asp-controller="Services" asp-action="Index" class="stretched-link" aria-label="Services"></a>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card stat-card h-100">
            <div class="card-body d-flex align-items-center">
                <i class="bi bi-diagram-3 fs-1 text-primary me-3"></i>
                <div>
                    <div class="stat-value">@(this.Model.EnvironnementsCount)</div>
                    <div class="text-body-secondary">Environnements</div>
                </div>
                <a asp-controller="Environnements" asp-action="Index" class="stretched-link" aria-label="Environnements"></a>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card stat-card h-100">
            <div class="card-body d-flex align-items-center">
                <i class="bi bi-files fs-1 text-primary me-3"></i>
                <div>
                    <div class="stat-value">@(this.Model.MockFilesCount)</div>
                    <div class="text-body-secondary">Réponses mockées</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header"><i class="bi bi-toggles"></i> Bouchonnage global</div>
            <div class="card-body">
                @if (this.Model.IsBouchonActivated == true)
                {
                    <p><span class="badge text-bg-success">Activé</span> Les réponses enregistrées sont rejouées.</p>
                    <form asp-controller="Home" asp-action="Index" method="post">
                        <input type="hidden" name="isActivated" value="false"/>
                        <button type="submit" class="btn btn-outline-secondary"><i class="bi bi-pause-circle"></i> Désactiver</button>
                    </form>
                }
                else
                {
                    <p><span class="badge text-bg-secondary">Inactif</span> Les appels sont relayés aux services réels.</p>
                    <form asp-controller="Home" asp-action="Index" method="post">
                        <input type="hidden" name="isActivated" value="true"/>
                        <button type="submit" class="btn btn-primary"><i class="bi bi-play-circle"></i> Activer</button>
                    </form>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header"><i class="bi bi-lightning-charge"></i> Actions rapides</div>
            <div class="card-body d-flex flex-wrap gap-2 align-content-start">
                <a asp-controller="Services" asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Nouveau service</a>
                <a asp-controller="Environnements" asp-action="Create" class="btn btn-outline-primary"><i class="bi bi-plus-lg"></i> Nouvel environnement</a>
                <a asp-controller="BouchonsManager" asp-action="ImportFiles" class="btn btn-outline-secondary"><i class="bi bi-upload"></i> Importer</a>
                <a href="/swagger" class="btn btn-outline-secondary"><i class="bi bi-file-earmark-code"></i> API</a>
            </div>
        </div>
    </div>
</div>

<p class="text-body-secondary mt-3 small"><i class="bi bi-folder"></i> Répertoire des bouchons : <code>@(this.Model.FilesPath)</code></p>
