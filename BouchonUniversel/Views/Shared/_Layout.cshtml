<!DOCTYPE html>
<html lang="fr">
@{
    var controller = this.ViewContext.RouteData.Values["controller"]?.ToString();
    string Active(string name) => string.Equals(controller, name, System.StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty;
}
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@(this.ViewData["Title"]) - Bouchon Universel</title>

    <script>
        (function () {
            var t = localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
            document.documentElement.setAttribute('data-bs-theme', t);
        })();
    </script>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    @(this.RenderSection("Styles", required: false))
</head>
<body>
<nav class="navbar bg-body-tertiary border-bottom fixed-top app-navbar">
    <div class="container-fluid">
        <button class="btn btn-outline-secondary d-lg-none me-2" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebar" aria-controls="sidebar">
            <i class="bi bi-list"></i>
        </button>
        <a class="navbar-brand" asp-controller="Home" asp-action="Index">
            <i class="bi bi-plug-fill text-primary"></i> <span class="fw-semibold">Bouchon Universel</span>
        </a>
        <div class="ms-auto d-flex align-items-center gap-2">
            <button id="theme-toggle" class="btn btn-outline-secondary btn-sm" type="button" title="Basculer clair/sombre">
                <i class="bi bi-moon-stars"></i>
            </button>
            @if (this.User?.Identity?.IsAuthenticated == true)
            {
                <span class="navbar-text d-none d-sm-inline"><i class="bi bi-person-circle"></i> @(this.User.Identity.Name)</span>
                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                    <button type="submit" class="btn btn-outline-secondary btn-sm" title="Déconnexion"><i class="bi bi-box-arrow-right"></i></button>
                </form>
            }
        </div>
    </div>
</nav>

<div class="app-body">
    <div class="offcanvas-lg offcanvas-start app-sidebar" tabindex="-1" id="sidebar">
        <div class="offcanvas-header d-lg-none border-bottom">
            <h5 class="offcanvas-title">Menu</h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" data-bs-target="#sidebar"></button>
        </div>
        <div class="offcanvas-body p-0">
            <nav class="nav flex-column p-2 w-100">
                <a class="nav-link @Active("Home")" asp-controller="Home" asp-action="Index"><i class="bi bi-speedometer2"></i> Tableau de bord</a>
                <a class="nav-link @Active("Services")" asp-controller="Services" asp-action="Index"><i class="bi bi-hdd-network"></i> Services</a>
                <a class="nav-link @Active("Environnements")" asp-controller="Environnements" asp-action="Index"><i class="bi bi-diagram-3"></i> Environnements</a>

                <div class="sidebar-heading">Données</div>
                <a class="nav-link" asp-controller="BouchonsManager" asp-action="DownloadFiles"><i class="bi bi-download"></i> Exporter</a>
                <a class="nav-link @Active("BouchonsManager")" asp-controller="BouchonsManager" asp-action="ImportFiles"><i class="bi bi-upload"></i> Importer</a>
                <a class="nav-link" asp-controller="BouchonsManager" asp-action="BackupDatabase"><i class="bi bi-database-down"></i> Sauvegarder la base</a>

                <div class="sidebar-heading">Système</div>
                <a class="nav-link @Active("Install")" asp-controller="Install" asp-action="Index"><i class="bi bi-gear"></i> Installation</a>
                <a class="nav-link" href="/swagger"><i class="bi bi-file-earmark-code"></i> API (Swagger)</a>
            </nav>
        </div>
    </div>

    <main class="app-main">
        <div class="container-fluid p-3 p-md-4">
            @(this.RenderBody())
        </div>
    </main>
</div>

<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1090; margin-top: 3.5rem;">
    @if (this.TempData["Message"] != null)
    {
        <div class="toast align-items-center text-bg-primary border-0" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body">@(this.TempData["Message"])</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Fermer"></button>
            </div>
        </div>
    }
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script>
    (function () {
        var btn = document.getElementById('theme-toggle');
        function icon() {
            var dark = document.documentElement.getAttribute('data-bs-theme') === 'dark';
            btn.querySelector('i').className = dark ? 'bi bi-sun' : 'bi bi-moon-stars';
        }
        icon();
        btn.addEventListener('click', function () {
            var next = document.documentElement.getAttribute('data-bs-theme') === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-bs-theme', next);
            localStorage.setItem('theme', next);
            icon();
        });
        document.querySelectorAll('.toast').forEach(function (t) { new bootstrap.Toast(t, { delay: 4000 }).show(); });
    })();
</script>

@(this.RenderSection("Scripts", false))
</body>
</html>
