<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@(this.ViewData["Title"]) - BouchonUniversel</title>

    <script>
        // Applique le thème avant le rendu pour éviter tout clignotement.
        (function () {
            var t = localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
            document.documentElement.setAttribute('data-bs-theme', t);
        })();
    </script>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    @(this.RenderSection("Styles", required: false))
</head>
<body>
<nav class="navbar navbar-expand-lg bg-body-tertiary border-bottom fixed-top">
    <div class="container">
        <a class="navbar-brand" asp-controller="Home" asp-action="Index"><i class="bi bi-plug-fill text-primary"></i> BouchonUniversel</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Basculer la navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="mainNav">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item"><a class="nav-link" href="/swagger"><i class="bi bi-file-earmark-code"></i> Swagger</a></li>
                <li class="nav-item"><a class="nav-link" asp-controller="Services" asp-action="Index"><i class="bi bi-hdd-network"></i> Services</a></li>
                <li class="nav-item"><a class="nav-link" asp-controller="Environnements" asp-action="Index"><i class="bi bi-diagram-3"></i> Environnements</a></li>
                <li class="nav-item"><a class="nav-link" asp-controller="BouchonsManager" asp-action="DownloadFiles"><i class="bi bi-download"></i> Exporter</a></li>
                <li class="nav-item"><a class="nav-link" asp-controller="BouchonsManager" asp-action="ImportFiles"><i class="bi bi-upload"></i> Importer</a></li>
                <li class="nav-item"><a class="nav-link" asp-controller="BouchonsManager" asp-action="BackupDatabase"><i class="bi bi-database-down"></i> Sauvegarde</a></li>
                <li class="nav-item"><a class="nav-link" asp-controller="Install" asp-action="Index"><i class="bi bi-gear"></i> Installation</a></li>
            </ul>
            <ul class="navbar-nav align-items-lg-center">
                <li class="nav-item me-lg-2">
                    <button id="theme-toggle" class="btn btn-outline-secondary btn-sm" type="button" title="Basculer clair/sombre">
                        <i class="bi bi-moon-stars"></i>
                    </button>
                </li>
                @if (this.User?.Identity?.IsAuthenticated == true)
                {
                    <li class="nav-item"><span class="navbar-text me-2"><i class="bi bi-person-circle"></i> @(this.User.Identity.Name)</span></li>
                    <li class="nav-item">
                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                            <button type="submit" class="btn btn-outline-secondary btn-sm"><i class="bi bi-box-arrow-right"></i> Déconnexion</button>
                        </form>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>

<main class="container" style="padding-top: 5rem;">
    @(this.RenderBody())
    <hr/>
    <footer class="text-body-secondary pb-3">
        <p>&copy; 2026 - BouchonUniversel</p>
    </footer>
</main>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script>
    (function () {
        var btn = document.getElementById('theme-toggle');
        function icon() {
            var dark = document.documentElement.getAttribute('data-bs-theme') === 'dark';
            btn.querySelector('i').className = dark ? 'bi bi-sun' : 'bi bi-moon-stars';
        }
        icon();
        btn.addEventListener('click', function () {
            var next = document.documentElement.getAttribute('data-bs-theme') === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-bs-theme', next);
            localStorage.setItem('theme', next);
            icon();
        });
    })();
</script>

@(this.RenderSection("Scripts", false))
</body>
</html>
