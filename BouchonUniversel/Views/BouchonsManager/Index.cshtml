@model IEnumerable<BouchonUniversel.Models.Bouchons.Bouchon>

@{
    this.ViewData["Title"] = "Index";
    this.Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Index</h2>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
    <tr>
        <th>
            @(this.Html.DisplayNameFor(model => model.IsEnabled))
        </th>
        <th></th>
    </tr>
    </thead>
    <tbody>
    @foreach (var item in this.Model)
    {
        <tr>
            <td>
                @(this.Html.DisplayFor(modelItem => item.IsEnabled))
            </td>
            <td>
                @(this.Html.ActionLink("Edit", "Edit", new { item.BaseUrl, item.ServiceUrl })) |
                @(this.Html.ActionLink("Details", "Details", new { item.BaseUrl, item.ServiceUrl })) |
                @(this.Html.ActionLink("Delete", "Delete", new { item.BaseUrl, item.ServiceUrl }))
            </td>
        </tr>
    }
    </tbody>
</table>
