@model IEnumerable<BouchonUniversel.Models.Bouchons.Bouchon>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Index</h2>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
                <th>
                    @Html.DisplayNameFor(model => model.IsEnabled)
                </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.IsEnabled)
            </td>
            <td>
                @Html.ActionLink("Edit", "Edit", new { item.BaseUrl, item.ServiceUrl }) |
                @Html.ActionLink("Details", "Details", new { item.BaseUrl, item.ServiceUrl }) |
                @Html.ActionLink("Delete", "Delete", new { item.BaseUrl, item.ServiceUrl })
            </td>
        </tr>
}
    </tbody>
</table>
